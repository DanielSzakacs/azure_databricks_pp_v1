          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "353ac4fa",
      "displayName": "total_earthquakes",
      "queryLines": [
        "SELECT COUNT(*) AS total_earthquakes\r\n",
        "FROM gold_earthquake_dashboard_vw;"
      ]
    },
    {
      "name": "a1555e42",
      "displayName": "average_magnitude",
      "queryLines": [
        "SELECT ROUND(AVG(mag), 2) AS average_magnitude\r\n",
        "FROM gold_earthquake_dashboard_vw;"
      ]
    },
    {
      "name": "07b32995",
      "displayName": "strongest_earthquake",
      "queryLines": [
        "SELECT ROUND(MAX(mag), 2) AS strongest_earthquake\r\n",
        "FROM gold_earthquake_dashboard_vw;"
      ]
    },
    {
      "name": "9db42add",
      "displayName": "main_map_eq",
      "queryLines": [
        "SELECT\r\n",
        "  latitude,\r\n",
        "  longitude,\r\n",
        "  title,\r\n",
        "  place_description,\r\n",
        "  country_code,\r\n",
        "  mag,\r\n",
        "  sig,\r\n",
        "  event_time,\r\n",
        "  sig_class\r\n",
        "FROM gold_earthquake_dashboard_vw;"
      ]
    },
    {
      "name": "8f4c3b4b",
      "displayName": "eq_by_countries",
      "queryLines": [
        "SELECT\r\n",
        "  COALESCE(country_code, 'Unknown') AS country_code,\r\n",
        "  COUNT(*) AS earthquake_count\r\n",
        "FROM gold_earthquake_dashboard_vw\r\n",
        "GROUP BY COALESCE(country_code, 'Unknown')\r\n",
        "ORDER BY earthquake_count DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "458248f8",
      "displayName": "magnitude_distribution_chart",
      "queryLines": [
        "SELECT\r\n",
        "  magnitude_category,\r\n",
        "  COUNT(*) AS earthquake_count\r\n",
        "FROM gold_earthquake_dashboard_vw\r\n",
        "GROUP BY magnitude_category\r\n",
        "ORDER BY\r\n",
        "  CASE magnitude_category\r\n",
        "    WHEN 'Micro (<2.0)' THEN 1\r\n",
        "    WHEN 'Minor (2.0-3.9)' THEN 2\r\n",
        "    WHEN 'Light (4.0-4.9)' THEN 3\r\n",
        "    WHEN 'Moderate (5.0-5.9)' THEN 4\r\n",
        "    WHEN 'Strong (6.0-6.9)' THEN 5\r\n",
        "    WHEN 'Major (7.0+)' THEN 6\r\n",
        "  END;"
      ]
    },
    {
      "name": "75fcc26f",
      "displayName": "top_earthquakes",
      "queryLines": [
        "SELECT\r\n",
        "  *\r\n",
        "FROM gold_earthquake_dashboard_vw\r\n",
        "ORDER BY mag DESC, sig DESC\r\n",
        "LIMIT 10;"
      ]
    }
  ],
